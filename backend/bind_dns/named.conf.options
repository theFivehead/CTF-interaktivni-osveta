options {
    directory "/var/cache/bind";

    recursion yes;                 # enable caching resolver
    allow-recursion { any; };      # restrict in production!

    listen-on { any; };
    listen-on-v6 { any; };

    dnssec-validation auto;

    forwarders {
        9.9.9.9;
        1.1.1.1;
    };
};